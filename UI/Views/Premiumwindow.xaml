<Window x:Class="Flux.UI.Views.PremiumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flux Premium" Width="420" Height="540"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot"      Color="#0A0A0C"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8EE"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#606068"/>
        <SolidColorBrush x:Key="SilverDim"   Color="#505058"/>
        <SolidColorBrush x:Key="Gold"        Color="#F6C45B"/>
    </Window.Resources>

    <Border Background="{StaticResource BgRoot}" CornerRadius="20" MouseDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="12" Color="#000000" Opacity="0.9"/>
        </Border.Effect>
        <Grid>
            <!-- Gold glow top -->
            <Ellipse Width="300" Height="160" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="0,-50,0,0" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#F6C45B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0">
                    <Border VerticalAlignment="Bottom" Height="1" Margin="20,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#25F6C45B"   Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0">
                        <TextBlock Text="&#x2605;" Foreground="{StaticResource Gold}" FontSize="12" Margin="0,0,8,0"/>
                        <TextBlock Text="F L U X  P R E M I U M" Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                    <Button Click="CloseClick" Width="28" Height="28" HorizontalAlignment="Right"
                            Margin="0,0,14,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="&#x2715;" Foreground="{StaticResource SilverDim}" FontSize="11"/>
                    </Button>
                </Grid>

                <!-- Content -->
                <StackPanel Grid.Row="1" Margin="32,10,32,32">

                    <!-- Badge -->
                    <Border HorizontalAlignment="Center" CornerRadius="20" Padding="18,8"
                            Margin="0,0,0,16" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#25F6C45B" Offset="0"/>
                                <GradientStop Color="#10F6C45B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush><SolidColorBrush Color="#50F6C45B"/></Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#F6C45B" Opacity="0.25"/>
                        </Border.Effect>
                        <TextBlock Text="&#x2605;  UNLOCK PREMIUM  &#x2605;"
                                   Foreground="{StaticResource Gold}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Text="Ottieni accesso a 10 Tweaks avanzati" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10"
                               Margin="0,0,0,20"/>

                    <!-- Feature list -->
                    <Border CornerRadius="12" Padding="16,14" Margin="0,0,0,20" BorderThickness="1">
                        <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                        <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                        <StackPanel>
                            <TextBlock Text="I N C L U D E D  I N  P R E M I U M" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,10"/>
                            <ItemsControl>
                                <ItemsControl.Items>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  DNS over HTTPS — velocità di navigazione</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  TCP/IP Optimizer — latenza di rete</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  GPU Shader Cache cleaner</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  Disable Telemetry Windows</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  MSI Mode per GPU/NIC</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  HPET Disable — latenza CPU</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  Disable Xbox Game Bar</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  SSD Optimizer — TRIM + Defrag</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  Process Priority Scheduler</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">&#x2022;  Registry Cleaner avanzato</System:String>
                                </ItemsControl.Items>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" Margin="0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Price -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="10">Una tantum — nessun abbonamento</TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <TextBlock Text="&#x20AC; " Foreground="{StaticResource Gold}"
                                       FontFamily="Consolas" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="5" Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Consolas" FontSize="36" FontWeight="Bold"/>
                            <TextBlock Text=",00" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="22" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- PayPal button -->
                    <Button Click="PayClick" HorizontalAlignment="Stretch" Cursor="Hand"
                            BorderThickness="0" Padding="0,14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#35F6C45B" Offset="0"/>
                                            <GradientStop Color="#18F6C45B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush><SolidColorBrush Color="#60F6C45B"/></Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#F6C45B" Opacity="0.2"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#F6C45B" Opacity="0.4"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4B3;  " Foreground="{StaticResource Gold}" FontSize="14"/>
                            <TextBlock Text="P A G A  C O N  P A Y P A L" Foreground="{StaticResource Gold}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- License key input -->
                    <TextBlock Text="Hai già una licenza?" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" FontFamily="Consolas"
                               FontSize="10" Margin="0,16,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8,0,0,8" BorderThickness="1,1,0,1" Padding="12,8">
                            <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#20FFFFFF"/></Border.BorderBrush>
                            <TextBox x:Name="LicenseBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextPrimary}" CaretBrush="White"
                                     FontFamily="Consolas" FontSize="11"
                                     Text="" VerticalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="1" Click="ActivateClick" Cursor="Hand"
                                Padding="14,8" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="0,8,8,0" Padding="{TemplateBinding Padding}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#25FFFFFF" Offset="0"/>
                                                <GradientStop Color="#0FFFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#30FFFFFF"/></Border.BorderBrush>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="A T T I V A" Foreground="{StaticResource TextPrimary}"
                                       FontFamily="Consolas" FontSize="10"/>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="LicenseMsg" Text="" HorizontalAlignment="Center"
                               FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"
                               Foreground="#F07070"/>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
