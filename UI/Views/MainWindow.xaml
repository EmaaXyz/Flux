<Window x:Class="Flux.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Flux.UI.ViewModels"
        Title="Flux" Width="920" Height="640"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot"      Color="#0A0A0C"/>
        <SolidColorBrush x:Key="BgSidebar"   Color="#0E0E11"/>
        <SolidColorBrush x:Key="Silver"      Color="#C8C8D0"/>
        <SolidColorBrush x:Key="SilverDim"   Color="#505058"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8EE"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#606068"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#5B9CF6"/>
        <SolidColorBrush x:Key="Gold"        Color="#F6C45B"/>
        <Style x:Key="TweakCard" TargetType="Border">
            <Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#18FFFFFF" Offset="0"/><GradientStop Color="#08FFFFFF" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
            <Setter Property="CornerRadius" Value="12"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/><Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#30C8C8D0" Offset="0"/><GradientStop Color="#10808088" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
        </Style>
        <Style x:Key="LockedCard" TargetType="Border" BasedOn="{StaticResource TweakCard}">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="BorderBrush"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#30F6C45B" Offset="0"/><GradientStop Color="#10F6C45B" Offset="1"/></LinearGradientBrush></Setter.Value></Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/><Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border CornerRadius="8" Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SideIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Width" Value="36"/><Setter Property="Height" Value="36"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Bd" CornerRadius="9" Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{StaticResource BgRoot}" CornerRadius="16" MouseDown="OnTitleBarMouseDown">
        <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="10" Color="#000000" Opacity="0.8"/></Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="195"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" x:Name="SidebarBorder" Background="{StaticResource BgSidebar}" CornerRadius="16,0,0,16" BorderThickness="0,0,1,0">
                <Border.BorderBrush><SolidColorBrush Color="#15FFFFFF"/></Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="56"/>
                    </Grid.RowDefinitions>
                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Image Source="/Assets/FluxLogo.jpg" Width="26" Height="26" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip><EllipseGeometry RadiusX="13" RadiusY="13" Center="13,13"/></Image.Clip>
                        </Image>
                        <StackPanel>
                            <TextBlock Text="F L U X" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Text="SYSTEM MONITOR" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="8"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Nav -->
                    <StackPanel Grid.Row="1" Margin="8,8,8,0">
                        <Border Height="1" Margin="8,0,8,12" Background="#12FFFFFF"/>
                        <TextBlock Text="OVERVIEW" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="16,0,0,8"/>
                        <Border x:Name="NavTweaksIndicator" CornerRadius="8" Margin="0,0,0,2" Background="#15FFFFFF" BorderThickness="1" Cursor="Hand" MouseDown="NavToTweaks">
                            <Border.BorderBrush><SolidColorBrush Color="#20FFFFFF"/></Border.BorderBrush>
                            <TextBlock x:Name="NavTweaksLabel" x:FieldModifier="public" Text="  TWEAKS" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" Padding="16,10"/>
                        </Border>
                        <Border x:Name="NavMonitorIndicator" CornerRadius="8" Margin="0,0,0,2" Background="Transparent" BorderThickness="1" Cursor="Hand" MouseDown="NavToMonitor">
                            <Border.BorderBrush><SolidColorBrush Color="Transparent"/></Border.BorderBrush>
                            <TextBlock x:Name="NavMonitorLabel" x:FieldModifier="public" Text="  MONITOR" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="11" Padding="16,10"/>
                        </Border>
                        <Border Height="1" Margin="8,12,8,12" Background="#12FFFFFF"/>
                        <TextBlock Text="ACCOUNT" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="16,0,0,8"/>

                        <!-- Account card -->
                        <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,8" BorderThickness="1" Cursor="Hand" MouseDown="OpenPremium">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#18FFFFFF" Offset="0"/><GradientStop Color="#08FFFFFF" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Border.BorderBrush><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25C8C8D0" Offset="0"/><GradientStop Color="#10808088" Offset="1"/></LinearGradientBrush></Border.BorderBrush>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0">
                                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#255B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Border.Background>
                                        <TextBlock x:Name="UserInitial" Text="E" Foreground="#E8E8EE" FontFamily="Consolas" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="UserNameLabel" Text="Utente" Foreground="#E8E8EE" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock x:Name="UserPlanLabel" Text="Free" Foreground="#606068" FontFamily="Consolas" FontSize="9"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Plan badge -->
                                <Border x:Name="PlanBadge" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" BorderThickness="1">
                                    <Border.Background><SolidColorBrush x:Name="PlanBadgeBg" Color="#10FFFFFF"/></Border.Background>
                                    <Border.BorderBrush><SolidColorBrush x:Name="PlanBadgeBorder" Color="#20FFFFFF"/></Border.BorderBrush>
                                    <TextBlock x:Name="PlanBadgeText" Text="FREE" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,14,0,0" CornerRadius="10" Padding="12,8" BorderThickness="1">
                            <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Text="CPU" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9"/><TextBlock Text="{Binding TotalCpuLoad, StringFormat={}{0:F0}%}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Text="RAM" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9"/><TextBlock Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/></StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <!-- Bottom bar -->
                    <Grid Grid.Row="2" Margin="10,0,10,10">
                        <Border Height="1" VerticalAlignment="Top" Background="#12FFFFFF"/>
                        <Button Style="{StaticResource SideIconBtn}" Click="OpenSettings" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock Text="&#x2699;" FontSize="16" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI Symbol"/>
                        </Button>
                        <Button Style="{StaticResource SideIconBtn}" Click="DoLogout" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <TextBlock Text="&#x2192;" FontSize="16" Foreground="#F66B5B" FontFamily="Segoe UI Symbol"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Border VerticalAlignment="Bottom" Height="1" Margin="20,0">
                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="Transparent" Offset="0"/><GradientStop Color="#20C8C8D0" Offset="0.5"/><GradientStop Color="Transparent" Offset="1"/></LinearGradientBrush></Border.Background>
                    </Border>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                        <TextBlock x:Name="PageTitle" x:FieldModifier="public" Text="T W E A K S" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="PageSubtitle" x:FieldModifier="public" Text="   Ottimizzazione sistema" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button Click="MinimizeClick" Width="30" Height="26" Cursor="Hand" Background="Transparent" BorderThickness="0">
                            <Border Width="12" Height="1" Background="{StaticResource SilverDim}"/>
                        </Button>
                        <Button Click="CloseClick" Width="30" Height="26" Cursor="Hand" Background="Transparent" BorderThickness="0">
                            <TextBlock Text="X" Foreground="{StaticResource SilverDim}" FontSize="11" FontFamily="Consolas"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- TWEAKS PAGE -->
                <ScrollViewer x:Name="TweaksPage" x:FieldModifier="public" Grid.Row="1" VerticalScrollBarVisibility="Hidden" Visibility="Visible">
                    <StackPanel Margin="20,14,20,20">
                        <TextBlock Text="F R E E" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="2,0,0,10"/>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#304FD97A" Offset="0"/><GradientStop Color="#104FD97A" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="GO" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#4FD97A" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Gaming Mode" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Termina processi non essenziali e imposta Massime Prestazioni" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Command="{Binding ToggleGamingModeCommand}" Content="{Binding GamingModeButtonLabel}" Style="{StaticResource ActionBtn}" VerticalAlignment="Center"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#254FD97A" Offset="0"/><GradientStop Color="#104FD97A" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#504FD97A"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#4FD97A"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#30F6A45B" Offset="0"/><GradientStop Color="#10F6A45B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="PWR" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#F6A45B" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Power Plan High Performance" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Riduce la latenza CPU disabilitando il risparmio energetico" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="A P P L Y" VerticalAlignment="Center" Click="ApplyHighPerformance"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25F6A45B" Offset="0"/><GradientStop Color="#10F6A45B" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#50F6A45B"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#F6A45B"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#305B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="RAM" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#5B9CF6" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><TextBlock Text="RAM Flush  " Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="{Binding RamUsageLabel}" Foreground="{StaticResource AccentBlue}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/></StackPanel><TextBlock Text="Libera la standby list e svuota i cache di sistema" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="F L U S H" VerticalAlignment="Center" Click="FlushRam"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#255B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#505B9CF6"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#5B9CF6"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#309B7FF6" Offset="0"/><GradientStop Color="#109B7FF6" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="VFX" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#9B7FF6" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Disable Visual Effects" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Disabilita animazioni e trasparenze Windows per liberare CPU" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="A P P L Y" VerticalAlignment="Center" Click="DisableVisualFx"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#259B7FF6" Offset="0"/><GradientStop Color="#109B7FF6" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#509B7FF6"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#9B7FF6"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#30F66B5B" Offset="0"/><GradientStop Color="#10F66B5B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="TMP" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#F66B5B" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Clean Temp Files" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Svuota %TEMP%, Prefetch e la cartella temporanea di Windows" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="C L E A N" VerticalAlignment="Center" Click="CleanTemp"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25F66B5B" Offset="0"/><GradientStop Color="#10F66B5B" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#50F66B5B"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#F66B5B"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#304FD97A" Offset="0"/><GradientStop Color="#104FD97A" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="SYS" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#4FD97A" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Disable SysMain / Superfetch" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Ferma SysMain che pre-carica dati in RAM causando lag su SSD" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="D I S A B L E" VerticalAlignment="Center" Click="DisableSysMain"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#254FD97A" Offset="0"/><GradientStop Color="#104FD97A" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#504FD97A"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#4FD97A"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#305B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="DNS" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#5B9CF6" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Flush DNS Cache" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Svuota la cache DNS di Windows per risolvere problemi di connessione" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="F L U S H" VerticalAlignment="Center" Click="FlushDns"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#255B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#505B9CF6"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#5B9CF6"/></Button.Foreground></Button></Grid></Border>

                        <Border Style="{StaticResource TweakCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#30F6C45B" Offset="0"/><GradientStop Color="#10F6C45B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock Text="HBN" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#F6C45B" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="Disable Hibernation" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Disabilita ibernazione e recupera spazio su disco (hiberfil.sys)" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="2" Style="{StaticResource ActionBtn}" Content="D I S A B L E" VerticalAlignment="Center" Click="DisableHibernation"><Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25F6C45B" Offset="0"/><GradientStop Color="#10F6C45B" Offset="1"/></LinearGradientBrush></Button.Background><Button.BorderBrush><SolidColorBrush Color="#50F6C45B"/></Button.BorderBrush><Button.Foreground><SolidColorBrush Color="#F6C45B"/></Button.Foreground></Button></Grid></Border>
                        <Grid Margin="0,14,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="* PREMIUM" Foreground="{StaticResource Gold}" FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/><TextBlock Text="   18 tweaks avanzati" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/></StackPanel><Button Grid.Column="1" Click="OpenPremiumBtn" Cursor="Hand" Padding="12,5"><Button.Template><ControlTemplate TargetType="Button"><Border CornerRadius="8" Padding="{TemplateBinding Padding}" BorderThickness="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25F6C45B" Offset="0"/><GradientStop Color="#10F6C45B" Offset="1"/></LinearGradientBrush></Border.Background><Border.BorderBrush><SolidColorBrush Color="#50F6C45B"/></Border.BorderBrush><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template><TextBlock Text="* Sblocca  5 EUR" Foreground="{StaticResource Gold}" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/></Button></Grid>
                        <Border Style="{StaticResource LockedCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center" Background="#15F6C45B"><TextBlock Text="LCK" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#F6C45B" FontWeight="Bold"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="DNS over HTTPS" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/><TextBlock Text="Velocizza la navigazione con DNS cifrati e a bassa latenza" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0"/></StackPanel><Border Grid.Column="2" CornerRadius="8" Padding="10,5" VerticalAlignment="Center" Background="#15F6C45B" BorderThickness="1"><Border.BorderBrush><SolidColorBrush Color="#30F6C45B"/></Border.BorderBrush><TextBlock Text="* PREMIUM" Foreground="{StaticResource Gold}" FontFamily="Consolas" FontSize="9"/></Border></Grid></Border>
