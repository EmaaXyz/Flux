<Window x:Class="Flux.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flux" Width="420" Height="600"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot"      Color="#0A0A0C"/>
        <SolidColorBrush x:Key="Silver"      Color="#C8C8D0"/>
        <SolidColorBrush x:Key="SilverDim"   Color="#505058"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8EE"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#606068"/>

        <Style x:Key="GlassInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#10FFFFFF"/>
            <Setter Property="Foreground"      Value="#E8E8EE"/>
            <Setter Property="CaretBrush"      Value="#C8C8D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,11"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#45C8C8D0" Offset="0"/>
                        <GradientStop Color="#18808088" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassPassword" TargetType="PasswordBox">
            <Setter Property="Background"      Value="#10FFFFFF"/>
            <Setter Property="Foreground"      Value="#E8E8EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,11"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#45C8C8D0" Offset="0"/>
                        <GradientStop Color="#18808088" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="#E8E8EE"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="0,13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10" Padding="{TemplateBinding Padding}" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2AFFFFFF" Offset="0"/>
                                    <GradientStop Color="#0AFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#70C8C8D0" Offset="0"/>
                                    <GradientStop Color="#25808088" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#C8C8D0" Opacity="0.12"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#C8C8D0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="#606068"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0,8"/>
        </Style>

        <!-- Checkbox style -->
        <Style x:Key="GlassCheck" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#606068"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgRoot}" CornerRadius="20" MouseDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="12" Color="#000000" Opacity="0.85"/>
        </Border.Effect>
        <Grid>
            <Ellipse Width="300" Height="160" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="0,-40,0,0" Opacity="0.04">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C8C8D0" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0">
                    <Border VerticalAlignment="Bottom" Height="1" Margin="20,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#30C8C8D0"   Offset="0.4"/>
                                <GradientStop Color="#30C8C8D0"   Offset="0.6"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0">
                        <Image Source="/Assets/FluxLogo.jpg" Width="20" Height="20"
                               Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="F L U X" Foreground="{StaticResource TextPrimary}"
                                   FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                    <Button Click="CloseClick" Width="28" Height="28" HorizontalAlignment="Right"
                            Margin="0,0,14,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <TextBlock Text="&#x2715;" Foreground="{StaticResource SilverDim}" FontSize="11"/>
                    </Button>
                </Grid>

                <!-- Scrollable content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="32,16,32,32">

                        <!-- Logo -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,8,0,24">
                            <Border Width="70" Height="70" CornerRadius="35"
                                    HorizontalAlignment="Center" Margin="0,0,0,12"
                                    BorderThickness="1" Background="White">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#55C8C8D0" Offset="0"/>
                                        <GradientStop Color="#18808088" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#C8C8D0" Opacity="0.18"/>
                                </Border.Effect>
                                <Image Source="/Assets/FluxLogo.jpg" Width="50" Height="50"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <TextBlock Text="SYSTEM MONITOR" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="9"/>
                        </StackPanel>

                        <!-- Tab switcher -->
                        <Border CornerRadius="10" Padding="4" Margin="0,0,0,22" BorderThickness="1">
                            <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="TabIndicator" Grid.Column="0" CornerRadius="7" BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#25FFFFFF" Offset="0"/>
                                            <GradientStop Color="#0FFFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#55C8C8D0" Offset="0"/>
                                            <GradientStop Color="#20808088" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                </Border>
                                <Button x:Name="BtnLogin" Grid.Column="0" Content="L O G I N"
                                        Style="{StaticResource TabBtn}"
                                        Foreground="{StaticResource TextPrimary}"
                                        Click="ShowLogin" Panel.ZIndex="1"/>
                                <Button x:Name="BtnRegister" Grid.Column="1" Content="R E G I S T E R"
                                        Style="{StaticResource TabBtn}"
                                        Click="ShowRegister" Panel.ZIndex="1"/>
                            </Grid>
                        </Border>

                        <!-- LOGIN PANEL -->
                        <StackPanel x:Name="LoginPanel" Visibility="Visible">
                            <TextBlock Text="U S E R N A M E" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="10" Margin="2,0,0,6"/>
                            <TextBox x:Name="LoginUser" Style="{StaticResource GlassInput}" Margin="0,0,0,14"/>

                            <TextBlock Text="P A S S W O R D" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="10" Margin="2,0,0,6"/>
                            <PasswordBox x:Name="LoginPass" Style="{StaticResource GlassPassword}" Margin="0,0,0,12"/>

                            <!-- Remember me -->
                            <CheckBox x:Name="RememberMe" Style="{StaticResource GlassCheck}"
                                      Content="Ricordami al prossimo avvio" Margin="2,0,0,4"/>

                            <TextBlock x:Name="LoginError" Text="" Foreground="#F07070"
                                       FontFamily="Consolas" FontSize="10"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

                            <Button Content="L O G I N" Style="{StaticResource PrimaryBtn}"
                                    HorizontalAlignment="Stretch" Margin="0,16,0,0"
                                    Click="DoLogin"/>
                        </StackPanel>

                        <!-- REGISTER PANEL -->
                        <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                            <TextBlock Text="U S E R N A M E" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="10" Margin="2,0,0,6"/>
                            <TextBox x:Name="RegUser" Style="{StaticResource GlassInput}" Margin="0,0,0,14"/>

                            <TextBlock Text="P A S S W O R D" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="10" Margin="2,0,0,6"/>
                            <PasswordBox x:Name="RegPass" Style="{StaticResource GlassPassword}" Margin="0,0,0,14"/>

                            <TextBlock Text="C O N F I R M  P A S S W O R D" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="10" Margin="2,0,0,6"/>
                            <PasswordBox x:Name="RegConfirm" Style="{StaticResource GlassPassword}" Margin="0,0,0,12"/>

                            <!-- Remember me register -->
                            <CheckBox x:Name="RememberMeReg" Style="{StaticResource GlassCheck}"
                                      Content="Ricordami al prossimo avvio" Margin="2,0,0,4"/>

                            <TextBlock x:Name="RegError" Text="" Foreground="#F07070"
                                       FontFamily="Consolas" FontSize="10"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

                            <Button Content="C R E A T E  A C C O U N T" Style="{StaticResource PrimaryBtn}"
                                    HorizontalAlignment="Stretch" Margin="0,16,0,0"
                                    Click="DoRegister"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
