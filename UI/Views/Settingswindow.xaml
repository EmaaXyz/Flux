<Window x:Class="Flux.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flux Settings" Width="420" Height="560"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot"      Color="#0A0A0C"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8E8EE"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#606068"/>
        <SolidColorBrush x:Key="SilverDim"   Color="#505058"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#5B9CF6"/>
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0,10"/>
            <Setter Property="Template"><Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgRoot}" CornerRadius="18" MouseDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="10" Color="#000000" Opacity="0.85"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0">
                <Border VerticalAlignment="Bottom" Height="1" Margin="20,0">
                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="Transparent" Offset="0"/><GradientStop Color="#25C8C8D0" Offset="0.5"/><GradientStop Color="Transparent" Offset="1"/></LinearGradientBrush></Border.Background>
                </Border>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0">
                    <TextBlock Text="&#x2699;" Foreground="{StaticResource AccentBlue}" FontSize="14" FontFamily="Segoe UI Symbol" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleLabel" Text="S E T T I N G S" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
                <Button Click="CloseClick" Width="28" Height="28" HorizontalAlignment="Right" Margin="0,0,14,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="X" Foreground="{StaticResource SilverDim}" FontFamily="Consolas" FontSize="11"/>
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="28,14,28,28">

                <!-- LANGUAGE -->
                <TextBlock x:Name="LangSectionLabel" Text="L A N G U A G E" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="2,0,0,10"/>
                <Border CornerRadius="12" Padding="4" Margin="0,0,0,18" BorderThickness="1">
                    <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                    <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                    <Grid x:Name="LangGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="LangIndicator" Grid.Column="0" CornerRadius="8" BorderThickness="1" Panel.ZIndex="0">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#255B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#505B9CF6"/></Border.BorderBrush>
                        </Border>
                        <Button Grid.Column="0" Style="{StaticResource TabBtn}" Click="SetItaliano" Panel.ZIndex="1">
                            <TextBlock x:Name="LblIT" Text="IT" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource TabBtn}" Click="SetEnglish" Panel.ZIndex="1">
                            <TextBlock x:Name="LblEN" Text="EN" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource TabBtn}" Click="SetFrancais" Panel.ZIndex="1">
                            <TextBlock x:Name="LblFR" Text="FR" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- THEME -->
                <TextBlock x:Name="ThemeSectionLabel" Text="T H E M E" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="2,0,0,10"/>
                <Border CornerRadius="12" Padding="4" Margin="0,0,0,18" BorderThickness="1">
                    <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                    <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border x:Name="ThemeIndicator" Grid.Column="0" CornerRadius="8" BorderThickness="1" Panel.ZIndex="0">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#25FFFFFF" Offset="0"/><GradientStop Color="#10FFFFFF" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#40C8C8D0"/></Border.BorderBrush>
                        </Border>
                        <Button Grid.Column="0" Style="{StaticResource TabBtn}" Click="SetDark" Panel.ZIndex="1">
                            <TextBlock x:Name="LblDark"  Text="Dark"  Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="11" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource TabBtn}" Click="SetLight" Panel.ZIndex="1">
                            <TextBlock x:Name="LblLight" Text="Light" Foreground="{StaticResource TextMuted}"   FontFamily="Consolas" FontSize="11" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- LICENSE KEY -->
                <TextBlock x:Name="KeySectionLabel" Text="L I C E N Z A" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="2,0,0,10"/>
                <Border CornerRadius="12" Padding="14,12" Margin="0,0,0,18" BorderThickness="1">
                    <Border.Background><SolidColorBrush Color="#08FFFFFF"/></Border.Background>
                    <Border.BorderBrush><SolidColorBrush Color="#18FFFFFF"/></Border.BorderBrush>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <!-- Key input -->
                            <Border Grid.Column="0" CornerRadius="8" Padding="10,0" Margin="0,0,8,0" BorderThickness="1">
                                <Border.Background><SolidColorBrush Color="#10FFFFFF"/></Border.Background>
                                <Border.BorderBrush><SolidColorBrush Color="#20FFFFFF"/></Border.BorderBrush>
                                <TextBox x:Name="KeyInput"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource TextPrimary}"
                                         CaretBrush="{StaticResource AccentBlue}"
                                         FontFamily="Consolas" FontSize="11"
                                         VerticalAlignment="Center" Height="34"
                                         MaxLength="24"
                                         Text="FLUX-XXXX-XXXX-XXXX-XXXX"
                                         GotFocus="KeyInput_GotFocus"
                                         LostFocus="KeyInput_LostFocus"
                                         CharacterCasing="Upper"/>
                            </Border>
                            <!-- Activate button -->
                            <Button Grid.Column="1" x:Name="KeyActivateBtn" Click="ActivateKey" Cursor="Hand" Height="34" Padding="12,0" BorderThickness="1">
                                <Button.Template><ControlTemplate TargetType="Button">
                                    <Border CornerRadius="8" Padding="{TemplateBinding Padding}" BorderThickness="1">
                                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#255B9CF6" Offset="0"/><GradientStop Color="#105B9CF6" Offset="1"/></LinearGradientBrush></Border.Background>
                                        <Border.BorderBrush><SolidColorBrush Color="#505B9CF6"/></Border.BorderBrush>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate></Button.Template>
                                <TextBlock x:Name="KeyActivateLabel" Text="A T T I V A" Foreground="{StaticResource AccentBlue}" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                            </Button>
                        </Grid>
                        <!-- Status message -->
                        <TextBlock x:Name="KeyStatusLabel" Text="" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="2,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ABOUT -->
                <TextBlock x:Name="AboutSectionLabel" Text="A B O U T" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="9" Margin="2,0,0,10"/>
                <Border CornerRadius="12" Padding="16,14" BorderThickness="1">
                    <Border.Background><SolidColorBrush Color="#08FFFFFF"/></Border.Background>
                    <Border.BorderBrush><SolidColorBrush Color="#15FFFFFF"/></Border.BorderBrush>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Flux System Monitor" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                            <TextBlock x:Name="VersionLabel"   Text="Version 1.0.0 — 2026" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10" Margin="0,4,0,2"/>
                            <TextBlock x:Name="PremiumStatus"  Text="Free" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10"/>
                        </StackPanel>
                        <Image Grid.Column="1" Source="/Assets/FluxLogo.jpg" Width="36" Height="36" VerticalAlignment="Center">
                            <Image.Clip><EllipseGeometry RadiusX="18" RadiusY="18" Center="18,18"/></Image.Clip>
                        </Image>
                    </Grid>
                </Border>

            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
